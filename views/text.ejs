<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saved Text - <%= shortId %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }

      .text-card {
        width: 100%;
        max-width: 860px;
        border-radius: 1rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 20px 30px rgba(15, 23, 42, 0.1);
      }

      .saved-text {
        min-height: 260px;
        resize: vertical;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", "Courier New", monospace;
      }
    </style>
  </head>
  <body>
    <div class="card text-card">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 mb-3">
          <i class="fas fa-file-lines me-2 text-primary"></i>Saved Text Snippet
        </h1>
        <p class="text-muted mb-4">
          Opened from:
          <a href="<%= baseURL %>/<%= shortId %>" class="text-decoration-none"
            ><%= baseURL %>/<%= shortId %></a
          >
        </p>

        <div class="mb-4">
          <label for="saved-text" class="form-label fw-semibold">Text</label>
          <textarea id="saved-text" class="form-control saved-text" readonly><%= textContent %></textarea>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <button
            type="button"
            class="btn btn-primary"
            onclick="copyToClipboard(document.getElementById('saved-text').value)"
          >
            <i class="fas fa-copy me-2"></i>Copy Text
          </button>
          <a href="/" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back Home
          </a>
        </div>
      </div>
    </div>

    <script>
      async function copyToClipboard(text) {
        try {
          await navigator.clipboard.writeText(text);
          alert("Text copied to clipboard!");
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      }
    </script>
  </body>
</html>
