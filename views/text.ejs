<!DOCTYPE html>
<html lang="en">
  <head>
    <script src="https://quge5.com/88/tag.min.js" data-zone="235003" async data-cfasync="false"></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Saved Text - <%= shortId %></title>
    <link rel="icon" type="image/svg+xml" href="/assets/nickly-logo.svg" />
    <link rel="shortcut icon" href="/assets/nickly-logo.svg" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
    />
    <script>
      window.va =
        window.va ||
        function () {
          (window.vaq = window.vaq || []).push(arguments);
        };
    </script>
    <script
      defer
      src="/_vercel/insights/script.js"
      data-sdkn="@vercel/analytics"
      data-sdkv="2.0.1"
    ></script>
    <script>
      (function () {
        try {
          const saved = localStorage.getItem("nickly-theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.dataset.theme = saved || (systemDark ? "dark" : "light");
        } catch (err) {}
      })();
    </script>
    <style>
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }

      .text-card {
        width: 100%;
        max-width: 860px;
        border-radius: 1rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 20px 30px rgba(15, 23, 42, 0.1);
      }

      .saved-text {
        min-height: 260px;
        resize: vertical;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", "Courier New", monospace;
      }

      .page-logo {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.22);
      }
    </style>
    <link rel="stylesheet" href="/assets/theme.css" />
    <script defer src="/assets/theme.js"></script>
  </head>
  <body>
    <div class="card text-card">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 mb-3">
          <img src="/assets/nickly-logo.svg" alt="Nickly" class="page-logo me-2" />Saved Text Snippet
        </h1>
        <p class="text-muted mb-4">
          Opened from:
          <a href="<%= baseURL %>/<%= shortId %>" class="text-decoration-none"
            ><%= baseURL %>/<%= shortId %></a
          >
        </p>

        <div class="mb-4">
          <label for="saved-text" class="form-label fw-semibold">Text</label>
          <textarea id="saved-text" class="form-control saved-text" readonly><%= textContent %></textarea>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <button
            type="button"
            class="btn btn-primary"
            onclick="copyToClipboard(document.getElementById('saved-text').value)"
          >
            <i class="fas fa-copy me-2"></i>Copy Text
          </button>
          <a href="/" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back Home
          </a>
        </div>
      </div>
    </div>

    <script>
      async function copyToClipboard(text) {
        try {
          await navigator.clipboard.writeText(text);
          alert("Text copied to clipboard!");
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      }
    </script>
  </body>
</html>
