    <style>
      :root {
        --primary-color: #6366f1;
        --secondary-color: #f8fafc;
        --text-primary: #1e293b;
        --text-secondary: #475569;
        --border-color: #e2e8f0;
        --content-bg: #ffffff;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: "Inter", sans-serif;
        background: url("https://static.vecteezy.com/system/resources/previews/002/289/261/large_2x/school-education-seamless-pattern-education-symbols-sketch-backdrop-with-school-supplies-back-to-school-icons-doodle-line-art-notebook-background-vector.jpg") no-repeat center center;
        background-repeat: repeat;
        background-size: 80rem 80rem;
        min-height: 100vh;
        color: var(--text-primary);
        line-height: 1.8;
      }

      .container-custom {
        max-width: 850px;
        margin: 0 auto;
        padding: 2rem 1rem;
      }

      .post-container {
        background: var(--content-bg);
        border-radius: 16px;
        padding: 3rem 4rem;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        border: 1px solid var(--border-color);
        margin-bottom: 4rem;
      }

      .post-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
      }

      .post-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--text-primary);
        line-height: 1.2;
      }

      .post-meta {
        font-size: 0.95rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
      }

      .post-content {
        font-size: 1.1rem;
        color: var(--text-secondary);
      }

      .post-content h2 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
      }

      .post-content h3 {
        font-size: 1.4rem;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
      }

      .post-content p {
        margin-bottom: 1.5rem;
      }

      .post-content ul, .post-content ol {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
      }

      .post-content li {
        margin-bottom: 0.5rem;
      }

      .post-content strong {
        color: var(--text-primary);
      }

      .back-to-blog {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2rem;
        font-weight: 500;
        transition: color 0.2s;
      }

      .back-to-blog:hover {
        color: var(--primary-color);
      }

      .recent-posts {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 2px solid var(--border-color);
      }

      .recent-posts-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 2rem;
      }

      .recent-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.5rem;
      }

      .recent-card {
        background: var(--secondary-color);
        padding: 1.5rem;
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--border-color);
        transition: transform 0.2s, box-shadow 0.2s;
      }

      .recent-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        color: inherit;
      }

      .recent-card h4 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
      }

      .recent-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin: 0;
      }

      @media (max-width: 768px) {
        .post-container {
          padding: 2rem 1.5rem;
        }
        .post-title {
          font-size: 2rem;
        }
      }
    </style>
