<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard | Nickly</title>
    <link rel="icon" type="image/svg+xml" href="/assets/nickly-logo.svg" />
    <link rel="shortcut icon" href="/assets/nickly-logo.svg" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script>
      window.va =
        window.va ||
        function () {
          (window.vaq = window.vaq || []).push(arguments);
        };
    </script>
    <script
      defer
      src="/_vercel/insights/script.js"
      data-sdkn="@vercel/analytics"
      data-sdkv="2.0.1"
    ></script>
    <script>
      (function () {
        try {
          const saved = localStorage.getItem("nickly-theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.dataset.theme = saved || (systemDark ? "dark" : "light");
        } catch (err) {}
      })();
    </script>

    <style>
      :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --accent: #10b981;
        --danger: #ef4444;
        --danger-dark: #dc2626;
        --bg: #f8fafc;
        --bg-card: #ffffff;
        --bg-card-hover: #f1f5f9;
        --text: #0f172a;
        --text-muted: #64748b;
        --border: #e2e8f0;
      }

      :root[data-theme="dark"] {
        --bg: #0f172a;
        --bg-card: rgba(15, 23, 42, 0.75);
        --bg-card-hover: rgba(30, 41, 59, 0.85);
        --text: #f8fafc;
        --text-muted: #94a3b8;
        --border: rgba(51, 65, 85, 0.6);
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: "Inter", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }

      .admin-nav {
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
      }

      .admin-nav .brand {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .admin-logo {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.35);
      }

      .admin-nav .nav-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .admin-nav .nav-right a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
      }

      .admin-nav .nav-right a:hover { color: var(--text); }

      .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.25rem;
        margin-bottom: 2rem;
      }

      .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        transition: transform 0.2s, border-color 0.2s;
      }

      .stat-card:hover {
        transform: translateY(-3px);
        border-color: var(--primary);
      }

      .stat-card .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin: 0 auto 0.75rem;
      }

      .stat-card .stat-value {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 0.25rem;
      }

      .stat-card .stat-label {
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 500;
      }

      .section-title {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .toolbar {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
      }

      .toolbar .search-box {
        flex: 1;
        min-width: 250px;
        padding: 0.6rem 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
      }

      .toolbar .search-box:focus {
        border-color: var(--primary);
      }

      .toolbar .search-box::placeholder {
        color: var(--text-muted);
      }

      .toolbar select {
        padding: 0.6rem 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        color: var(--text);
        font-size: 0.9rem;
        cursor: pointer;
        outline: none;
      }

      .toolbar select option {
        background: var(--bg-card);
      }

      .toolbar .filter-btn {
        padding: 0.6rem 1.25rem;
        background: var(--primary);
        border: none;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.2s;
      }

      .toolbar .filter-btn:hover {
        background: var(--primary-dark);
      }

      .data-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 2rem;
      }

      .data-table thead th {
        background: rgba(99, 102, 241, 0.15);
        color: var(--primary);
        font-weight: 600;
        padding: 1rem;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }

      .data-table tbody td {
        padding: 0.9rem 1rem;
        border-bottom: 1px solid rgba(51, 65, 85, 0.5);
        font-size: 0.9rem;
        vertical-align: middle;
      }

      .data-table tbody tr {
        transition: background 0.15s;
      }

      .data-table tbody tr:hover {
        background: var(--bg-card-hover);
      }

      .data-table tbody tr:last-child td {
        border-bottom: none;
      }

      .badge-type {
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
      }

      .badge-type.url {
        background: rgba(16, 185, 129, 0.2);
        color: #34d399;
      }

      .badge-type.text {
        background: rgba(99, 102, 241, 0.2);
        color: #818cf8;
      }

      .badge-role {
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 600;
      }

      .badge-role.admin {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
      }

      .badge-role.user {
        background: rgba(148, 163, 184, 0.2);
        color: var(--text-muted);
      }

      .short-link {
        font-family: "Monaco", "Menlo", monospace;
        color: var(--accent);
        text-decoration: none;
        font-size: 0.85rem;
        word-break: break-all;
      }

      .short-link:hover { text-decoration: underline; color: var(--accent); }

      .dest-link {
        color: var(--text-muted);
        text-decoration: none;
        max-width: 200px;
        display: inline-block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-size: 0.85rem;
      }

      .dest-link:hover { color: var(--text); }

      .views-badge {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
        padding: 0.3rem 0.7rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .btn-delete {
        background: transparent;
        border: 1px solid var(--danger);
        color: var(--danger);
        padding: 0.4rem 0.9rem;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .btn-delete:hover {
        background: var(--danger);
        color: white;
      }

      .text-preview {
        color: var(--text-muted);
        max-width: 200px;
        display: inline-block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-style: italic;
        font-size: 0.85rem;
      }

      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
      }

      .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.4;
      }

      .section-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
      }

      .confirm-dialog {
        display: none;
      }

      @media (max-width: 768px) {
        .admin-container { padding: 1rem; }
        .toolbar { flex-direction: column; }
        .toolbar .search-box { min-width: auto; }
        .data-table { font-size: 0.8rem; }
        .data-table thead th,
        .data-table tbody td { padding: 0.65rem 0.5rem; }
      }
    </style>
    <link rel="stylesheet" href="/assets/theme.css" />
    <script defer src="/assets/theme.js"></script>
  </head>

  <body>
    <!-- Nav -->
    <nav class="admin-nav">
      <a href="/admin" class="brand">
        <img src="/assets/nickly-logo.svg" alt="Nickly" class="admin-logo" />
        Admin Panel
      </a>
      <div class="nav-right">
        <span style="color: var(--text-muted); font-size: 0.85rem;">
          <i class="fas fa-user-shield me-1"></i> <%= user.username %>
        </span>
        <a href="/"><i class="fas fa-home me-1"></i> Home</a>
        <a href="/user/logout"><i class="fas fa-sign-out-alt me-1"></i> Logout</a>
      </div>
    </nav>

    <div class="admin-container">
      <!-- Stats -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-icon" style="background: rgba(99, 102, 241, 0.15); color: var(--primary);">
            <i class="fas fa-link"></i>
          </div>
          <div class="stat-value"><%= stats.totalLinks %></div>
          <div class="stat-label">Total Links</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background: rgba(16, 185, 129, 0.15); color: #34d399;">
            <i class="fas fa-globe"></i>
          </div>
          <div class="stat-value"><%= stats.totalUrls %></div>
          <div class="stat-label">URL Shortlinks</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background: rgba(59, 130, 246, 0.15); color: #60a5fa;">
            <i class="fas fa-file-lines"></i>
          </div>
          <div class="stat-value"><%= stats.totalTexts %></div>
          <div class="stat-label">Text Snippets</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background: rgba(239, 68, 68, 0.15); color: #f87171;">
            <i class="fas fa-users"></i>
          </div>
          <div class="stat-value"><%= stats.totalUsers %></div>
          <div class="stat-label">Registered Users</div>
        </div>
      </div>

      <!-- All Links Section -->
      <h2 class="section-title"><i class="fas fa-database"></i> All Links</h2>

      <form method="GET" action="/admin" class="toolbar">
        <input type="text" name="search" class="search-box" placeholder="Search by short ID, URL, or text..." value="<%= searchQuery %>" />
        <select name="sort">
          <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest First</option>
          <option value="oldest" <%= currentSort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
          <option value="text-first" <%= currentSort === 'text-first' ? 'selected' : '' %>>Text First</option>
          <option value="url-first" <%= currentSort === 'url-first' ? 'selected' : '' %>>URL First</option>
        </select>
        <select name="type">
          <option value="all" <%= currentType === 'all' ? 'selected' : '' %>>All Types</option>
          <option value="url" <%= currentType === 'url' ? 'selected' : '' %>>URLs Only</option>
          <option value="text" <%= currentType === 'text' ? 'selected' : '' %>>Text Only</option>
        </select>
        <button type="submit" class="filter-btn"><i class="fas fa-filter me-1"></i> Filter</button>
      </form>

      <% if (urls.length > 0) { %>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Short ID</th>
              <th>Type</th>
              <th>Destination / Content</th>
              <th>Visibility</th>
              <th>Views</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% urls.forEach((url, index) => { %>
            <% const entryType = url.entryType || "url"; %>
            <tr>
              <td style="color: var(--text-muted); font-weight: 500;"><%= index + 1 %></td>
              <td>
                <a href="<%= baseURL %>/<%= url.shortId %>" target="_blank" class="short-link">
                  <%= url.shortId %>
                </a>
              </td>
              <td>
                <span class="badge-type <%= entryType %>">
                  <i class="fas <%= entryType === 'text' ? 'fa-file-lines' : 'fa-link' %> me-1"></i>
                  <%= entryType %>
                </span>
              </td>
              <td>
                <% if (entryType === "text") { %>
                  <span class="text-preview" title="<%= url.textContent %>">
                    <%= (url.textContent || "").slice(0, 60) %><%= (url.textContent || "").length > 60 ? "..." : "" %>
                  </span>
                <% } else { %>
                  <a href="<%= url.redirectURL %>" target="_blank" class="dest-link" title="<%= url.redirectURL %>">
                    <%= url.redirectURL %>
                  </a>
                <% } %>
              </td>
              <td>
                <% if (url.isPublic === false) { %>
                  <span style="color: var(--text-muted);"><i class="fas fa-lock me-1"></i>Private</span>
                <% } else { %>
                  <span style="color: var(--accent);"><i class="fas fa-globe me-1"></i>Public</span>
                <% } %>
              </td>
              <td>
                <span class="views-badge">
                  <i class="fas fa-eye"></i> <%= (url.visitHistory || []).length %>
                </span>
              </td>
              <td style="color: var(--text-muted); font-size: 0.8rem; white-space: nowrap;">
                <%= url.createdAt ? new Date(url.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
              </td>
              <td>
                <form method="POST" action="/admin/delete-link/<%= url._id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this link?');">
                  <button type="submit" class="btn-delete">
                    <i class="fas fa-trash-alt"></i> Delete
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-inbox"></i>
        <h4>No links found</h4>
        <p>Try adjusting your filters or search query.</p>
      </div>
      <% } %>

      <!-- Users Section -->
      <h2 class="section-title" style="margin-top: 2rem;"><i class="fas fa-users-cog"></i> Registered Users</h2>

      <% if (users.length > 0) { %>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((u, index) => { %>
            <tr>
              <td style="color: var(--text-muted); font-weight: 500;"><%= index + 1 %></td>
              <td style="font-weight: 600;"><%= u.username %></td>
              <td style="color: var(--text-muted);"><%= u.email %></td>
              <td>
                <span class="badge-role <%= u.role || 'user' %>">
                  <i class="fas <%= (u.role === 'admin') ? 'fa-shield-halved' : 'fa-user' %> me-1"></i>
                  <%= u.role || 'user' %>
                </span>
              </td>
              <td style="color: var(--text-muted); font-size: 0.8rem; white-space: nowrap;">
                <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
              </td>
              <td>
                <% if (u._id.toString() !== user._id.toString()) { %>
                <% var isAdmin = (u.role === 'admin'); %>
                <% var roleAction = isAdmin ? 'Demote' : 'Promote'; %>
                <% var roleMsg = roleAction + ' ' + u.username + ' to ' + (isAdmin ? 'user' : 'admin') + '?'; %>
                <form method="POST" action="/admin/toggle-role/<%= u._id %>" style="display:inline;" onsubmit="return confirm('<%= roleMsg %>');">
                  <button type="submit" class="btn-delete" style="border-color: var(--primary); color: var(--primary); margin-right: 0.4rem;">
                    <i class="fas <%= isAdmin ? 'fa-arrow-down' : 'fa-arrow-up' %>"></i>
                    <%= roleAction %>
                  </button>
                </form>
                <form method="POST" action="/admin/delete-user/<%= u._id %>" style="display:inline;" onsubmit="return confirm('Delete user <%= u.username %> and ALL their links?');">
                  <button type="submit" class="btn-delete">
                    <i class="fas fa-user-xmark"></i> Remove
                  </button>
                </form>
                <% } else { %>
                <span style="color: var(--text-muted); font-size: 0.8rem;">You</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="empty-state">
        <i class="fas fa-users-slash"></i>
        <h4>No users registered</h4>
      </div>
      <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
